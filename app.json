{
  "expo": {
    "name": "safari-mobile-client",
    "slug": "safari-mobile-client",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/safaricharger.png",
    "scheme": "safarimobileclient",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/safaricharger.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/safaricharger.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}