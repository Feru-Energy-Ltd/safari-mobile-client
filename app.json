{
  "expo": {
    "name": "Safari Charger",
    "slug": "safari-mobile-client",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/safaricharger.png",
    "scheme": "safarimobileclient",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/safaricharger.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.safaricharger.safarimobileclient",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/safaricharger-adaptive.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.safaricharger.safarimobileclient"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b7b81c4e-d090-4ec1-8321-054a55921e8e"
      }
    },
    "owner": "safaricharger"
  }
}